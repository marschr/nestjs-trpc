{
  "name": "nestjs-trpc-workspace",
  "version": "1.6.1",
  "homepage": "https://nestjs-trpc.io",
  "private": true,
  "scripts": {
    "build": "tsc -b -v packages",
    "changelog": "lerna-changelog",
    "clean": "tsc -b --clean packages",
    "format": "prettier packages/**/*.ts --ignore-path ./.prettierignore --write",
    "test": "npm run test -ws --if-present",
    "release": "release-it",
    "prepublish:npm": "npm run build && lerna-changelog",
    "publish:npm": "lerna publish",
    "prepublish:next": "npm run build",
    "publish:next": "lerna publish --dist-tag next",
    "prepack": "pinst --disable",
    "postinstall": "husky",
    "postpack": "pinst --enable",
    "prepare": "husky"
  },
  "author": {
    "name": "Kevin Edry",
    "email": "kevin.edry@gmail.com",
    "url": "https://kevin-edry.com"
  },
  "license": "MIT",
  "engines": {
    "node": "18 || 19 || 20 || 22"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@commitlint/prompt-cli": "^19.3.1",
    "@nestjs/cli": "^9.3.0",
    "@release-it-plugins/workspaces": "^4.2.0",
    "@release-it/conventional-changelog": "^8.0.1",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.11",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "lint-staged": "15.2.7",
    "pinst": "^3.0.0",
    "prettier": "^3.3.3",
    "release-it": "17.1.1",
    "rimraf": "^4.4.1",
    "ts-jest": "29.2.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinEdry/nestjs-trpc"
  },
  "packageManager": "yarn@4.4.0+sha512.91d93b445d9284e7ed52931369bc89a663414e5582d00eea45c67ddc459a2582919eece27c412d6ffd1bd0793ff35399381cb229326b961798ce4f4cc60ddfdb"
}
